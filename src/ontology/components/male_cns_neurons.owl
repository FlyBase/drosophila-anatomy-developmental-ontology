                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0013003"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00047519"/>
            </owl:Restriction>

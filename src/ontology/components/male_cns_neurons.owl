    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_20001767"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Adult descending neuron of the anterior dorsal brain of the DNae008 group (Berg et al., 2025). It belongs to the WEDd1 hemilineage (Berg et al., 2025). It receives input in the ipsilateral gorget, vest, inferior clamp, superior posterior slope, inferior posterior slope, T1 leg neuropil and T3 leg neuropil, and the cervical connective, gnathal ganglion, inferior bridge, lower tectulum and abdominal neuromere (Berg et al., 2025). It sends output to the ipsilateral vest, inferior posterior slope, T1 leg neuropil, T2 leg neuropil and T3 leg neuropil, and the gnathal ganglion, lower tectulum, intermediate tectulum and abdominal neuromere (Berg et al., 2025). Its predicted neurotransmitter is acetylcholine (Eckstein et al., 2024; Berg et al., 2025).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0246888</oboInOwl:hasDbXref>

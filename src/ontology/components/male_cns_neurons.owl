                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00110173"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Adult descending neuron of the posterior brain of the DNpe026 group (Berg et al., 2025). It receives input in the ipsilateral superior medial protocerebrum, gorget, posterior lateral protocerebrum, superior clamp, inferior clamp and superior posterior slope, the contralateral vest and superior posterior slope, and the gnathal ganglion, inferior bridge, saddle, lower tectulum, intermediate tectulum and abdominal neuromere (Berg et al., 2025). It sends output to the ipsilateral superior clamp, inferior clamp and superior posterior slope, the contralateral vest, superior posterior slope, flange and cantle, and the gnathal ganglion, inferior bridge, saddle, lower tectulum, intermediate tectulum and abdominal neuromere (Berg et al., 2025). Its predicted neurotransmitter is acetylcholine (Eckstein et al., 2024; Berg et al., 2025).</obo:IAO_0000115>
        <terms:contributor rdf:resource="http://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-30T12:00:00Z</terms:date>

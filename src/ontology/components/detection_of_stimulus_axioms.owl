# ---------------------------------------------------------------
# EquivalentClasses axioms (replacing intersection_of definitions)
# ---------------------------------------------------------------

# FBbt:00048471 nociceptive neuron = neuron and capable_of some (detection_of_stimulus and part_of some sensory_perception_of_pain)
EquivalentClasses(obo:FBbt_00048471
  ObjectIntersectionOf(
    obo:FBbt_00005106
    ObjectSomeValuesFrom(obo:RO_0002215
      ObjectIntersectionOf(
        obo:GO_0051606
        ObjectSomeValuesFrom(obo:BFO_0000050 obo:GO_0019233)
      )
    )
  )
)

# FBbt:00049615 salt-sensing neuron = neuron and capable_of some (detection_of_chemical_stimulus and part_of some sensory_perception_of_salty_taste)
EquivalentClasses(obo:FBbt_00049615
  ObjectIntersectionOf(
    obo:FBbt_00005106
    ObjectSomeValuesFrom(obo:RO_0002215
      ObjectIntersectionOf(
        obo:GO_0009593
        ObjectSomeValuesFrom(obo:BFO_0000050 obo:GO_0050914)
      )
    )
  )
)

# FBbt:00049617 umami-sensing neuron = neuron and capable_of some (detection_of_chemical_stimulus and part_of some sensory_perception_of_umami_taste)
EquivalentClasses(obo:FBbt_00049617
  ObjectIntersectionOf(
    obo:FBbt_00005106
    ObjectSomeValuesFrom(obo:RO_0002215
      ObjectIntersectionOf(
        obo:GO_0009593
        ObjectSomeValuesFrom(obo:BFO_0000050 obo:GO_0050917)
      )
    )
  )
)

# FBbt:00100004 wind sensitive Johnston organ neuron = JON tonically activated by arista deflection and capable_of some (detection_of_mechanical_stimulus and part_of some sensory_perception_of_wind)
EquivalentClasses(obo:FBbt_00100004
  ObjectIntersectionOf(
    obo:FBbt_00100012
    ObjectSomeValuesFrom(obo:RO_0002215
      ObjectIntersectionOf(
        obo:GO_0050982
        ObjectSomeValuesFrom(obo:BFO_0000050 obo:GO_0071063)
      )
    )
  )
)

